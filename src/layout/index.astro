    <script is:inline>
      (function () {
        var art = document.getElementById('km-ascii').textContent.trim();
        var s = 'color:#4fbb4f;font-family:monospace;font-size:8.5px;line-height:1.15';
        console.log('%c' + art, s);
        console.log('%c Kevin Martínez', 'color:#d6cc3b;font-size:16px;font-weight:bold;font-family:monospace');
        console.log('%c Fullstack Developer · kmartinez.dev', 'color:#d8d6d6;font-size:11px;font-family:monospace');
      })();
    </script>

    <script is:inline>
      const hue = Math.floor(Math.random() * 360);
      const glow = document.getElementById("cursor-glow");
      glow.style.background = `hsl(${hue}, 80%, 60%)`;

      let tx = window.innerWidth / 2;
      let ty = window.innerHeight / 2;
      let cx = tx;
      let cy = ty;

      document.addEventListener("mousemove", (e) => {
        tx = e.clientX;
        ty = e.clientY;
      });

      (function animate() {
        cx += (tx - cx) * 0.08;
        cy += (ty - cy) * 0.08;
        glow.style.left = cx + "px";
        glow.style.top = cy + "px";
        requestAnimationFrame(animate);
      })();
    </script>

    <script is:inline>
      (function () {
        let observer = null;
        function initViewReveal() {
          if (observer) observer.disconnect();
          observer = null;
          const els = document.querySelectorAll("[data-view-reveal]");
          if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
            els.forEach(function (el) {
              el.classList.add("is-in-view");
            });
            return;
          }
          els.forEach(function (el) {
            el.classList.remove("is-in-view");
          });
          observer = new IntersectionObserver(
            function (entries) {
              let staggerIndex = 0;
              entries.forEach(function (entry) {
                if (!entry.isIntersecting) return;
                if ((entry.target.getAttribute("style") || "").indexOf("--view-reveal-delay") !== -1) {
                  entry.target.style.setProperty("--view-reveal-delay", staggerIndex * 110 + "ms");
                  staggerIndex++;
                }
                entry.target.classList.add("is-in-view");
                if (observer) observer.unobserve(entry.target);
              });
            },
            { root: null, rootMargin: "0px 0px -12% 0px", threshold: 0.08 },
          );
          els.forEach(function (el) {
            if (observer) observer.observe(el);
          });
        }
        initViewReveal();
        document.addEventListener("astro:page-load", initViewReveal);
      })();
    </script>
  </body>
</html>
