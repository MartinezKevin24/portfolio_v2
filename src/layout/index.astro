---
import "../styles/global.css";
import LangToggle from "../components/LangToggle/index.astro";
import Nav from "../components/Nav/index.astro";
import { useTranslations } from "../i18n/index";
import type { Lang } from "../i18n/index";

const lang = (Astro.currentLocale ?? "es") as Lang;
const t = useTranslations(lang);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{t("meta.title")}</title>
  </head>
  <body>
    <div id="cursor-glow" aria-hidden="true"></div>
    <div class="flex flex-col items-center md:py-12 py-6 px-4 min-h-screen relative z-10">
      <div class="w-full max-w-[1050px] flex justify-between items-center mb-4">
        <Nav />
        <LangToggle />
      </div>
      <main class="w-full max-w-[1050px] space-y-8 md:space-y-16 space-x-4">
        <slot />
      </main>
    </div>

    <script is:inline>
      const hue = Math.floor(Math.random() * 360);
      const glow = document.getElementById('cursor-glow');
      glow.style.background = `hsl(${hue}, 80%, 60%)`;

      let tx = window.innerWidth / 2;
      let ty = window.innerHeight / 2;
      let cx = tx;
      let cy = ty;

      document.addEventListener('mousemove', (e) => {
        tx = e.clientX;
        ty = e.clientY;
      });

      (function animate() {
        cx += (tx - cx) * 0.08;
        cy += (ty - cy) * 0.08;
        glow.style.left = cx + 'px';
        glow.style.top = cy + 'px';
        requestAnimationFrame(animate);
      })();
    </script>
  </body>
</html>
