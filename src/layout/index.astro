---
import "../styles/global.css";
import LangToggle from "../components/LangToggle/index.astro";
import { useTranslations } from "../i18n/index";
import type { Lang } from "../i18n/index";

const lang = (Astro.currentLocale ?? 'es') as Lang;
const t = useTranslations(lang);
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{t('meta.title')}</title>
  </head>
  <body>
    <div class="flex flex-col items-center md:py-12 py-6 px-4 min-h-screen">
      <div class="w-full max-w-[1050px] flex justify-end mb-4">
        <LangToggle />
      </div>
      <main class="w-full max-w-[1050px] space-y-4 space-x-4">
        <slot />
      </main>
    </div>
  </body>
</html>
