---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import LangToggle from "../components/LangToggle/index.astro";
import MobileNav from "../components/MobileNav/index.astro";
import Nav from "../components/Nav/index.astro";
import { useTranslations } from "../i18n/index";
import type { Lang } from "../i18n/index";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const SITE = "https://kmartinez.dev";

const { title, description, ogImage, noIndex = false, jsonLd } = Astro.props;
const lang = (Astro.currentLocale ?? "es") as Lang;
const t = useTranslations(lang);

const pageTitle = title ?? t("meta.title");
const pageDescription = description ?? t("meta.description");

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const isEn = lang === "en";

const esPath = isEn ? pathname.replace(/^\/en/, "") || "/" : pathname;
const enPath = isEn ? pathname : "/en" + (pathname === "/" ? "" : pathname);

const canonicalUrl = new URL(pathname === "/" ? "/" : pathname, SITE).href;
const esUrl = new URL(esPath, SITE).href;
const enUrl = new URL(enPath, SITE).href;

const ogImageUrl = ogImage ? new URL(ogImage, SITE).href : null;
const jsonLdItems = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <ClientRouter />

    <!-- Primary SEO -->
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="author" content="Kevin Martínez" />
    <link rel="canonical" href={canonicalUrl} />
    <meta
      name="robots"
      content={noIndex ? "noindex, follow" : "index, follow"}
    />

    <!-- Hreflang -->
    <link rel="alternate" hreflang="es" href={esUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={esUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:locale" content={isEn ? "en_US" : "es_MX"} />
    <meta property="og:site_name" content="Kevin Martínez" />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}

    <!-- Twitter Card -->
    <meta
      name="twitter:card"
      content={ogImageUrl ? "summary_large_image" : "summary"}
    />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon_memoji.webp" />

    <!-- JSON-LD -->
    {
      jsonLdItems.map((schema) => (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
      ))
    }
  </head>
  <body>
    <div id="cursor-glow" aria-hidden="true"></div>
    <div
      class="flex flex-col items-center md:py-12 py-6 px-4 min-h-screen relative z-10"
    >
      <div class="w-full max-w-[1050px] flex justify-between items-center mb-4">
        <Nav />
        <MobileNav />
        <LangToggle />
      </div>
      <main class="w-full max-w-[1050px] space-y-8 md:space-y-16">
        <slot />
      </main>
    </div>

    <script is:inline>
      const hue = Math.floor(Math.random() * 360);
      const glow = document.getElementById("cursor-glow");
      glow.style.background = `hsl(${hue}, 80%, 60%)`;

      let tx = window.innerWidth / 2;
      let ty = window.innerHeight / 2;
      let cx = tx;
      let cy = ty;

      document.addEventListener("mousemove", (e) => {
        tx = e.clientX;
        ty = e.clientY;
      });

      (function animate() {
        cx += (tx - cx) * 0.08;
        cy += (ty - cy) * 0.08;
        glow.style.left = cx + "px";
        glow.style.top = cy + "px";
        requestAnimationFrame(animate);
      })();
    </script>

    <script is:inline>
      (function () {
        let observer = null;
        function initViewReveal() {
          if (observer) observer.disconnect();
          observer = null;
          const els = document.querySelectorAll("[data-view-reveal]");
          if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
            els.forEach(function (el) {
              el.classList.add("is-in-view");
            });
            return;
          }
          els.forEach(function (el) {
            el.classList.remove("is-in-view");
          });
          observer = new IntersectionObserver(
            function (entries) {
              let staggerIndex = 0;
              entries.forEach(function (entry) {
                if (!entry.isIntersecting) return;
                if ((entry.target.getAttribute("style") || "").indexOf("--view-reveal-delay") !== -1) {
                  entry.target.style.setProperty("--view-reveal-delay", staggerIndex * 110 + "ms");
                  staggerIndex++;
                }
                entry.target.classList.add("is-in-view");
                if (observer) observer.unobserve(entry.target);
              });
            },
            { root: null, rootMargin: "0px 0px -12% 0px", threshold: 0.08 },
          );
          els.forEach(function (el) {
            if (observer) observer.observe(el);
          });
        }
        initViewReveal();
        document.addEventListener("astro:page-load", initViewReveal);
      })();
    </script>
  </body>
</html>
