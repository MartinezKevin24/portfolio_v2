---
import "../Projects/styles.css";
import "./styles.css";
import type { ProjectPreview } from "../../types/projects";
import type { Lang } from "../../i18n/index";

export interface Props {
  project: ProjectPreview;
  lang: Lang;
  techClassMap: Record<string, string>;
}

const { project, lang, techClassMap } = Astro.props;
const base = lang === "en" ? "/en" : "";
const detailHref = project.slug
  ? `${base}/projects/${project.slug}`
  : undefined;
---

<div
  class="project-card-wrapper"
  style={`--orb-color-1: ${project.colors[0]}; --orb-color-2: ${project.colors[1]};`}
>
  <div
    class="glass-card project-card project-preview-card text-primary group p-8 md:p-12 rounded-xl hover:bg-primary transition-all duration-300"
  >
    <div class="project-preview-card__media">
      <div class="project-preview-card__desktop-wrap">
        <img
          src={project.image_desktop}
          alt={project.name}
          class={`project-preview-card__desktop-img shadow-lg ${project.classes_images[0]}`}
        />
      </div>
      <img
        src={project.image_mobile}
        alt={project.name}
        class={project.classes_images[1]}
      />
    </div>
    <div class="project-preview-card__content">
      <div class="space-y-2">
        <div class="project-preview-card__title-row">
          <h2 class="font-bold text-4xl">
            {
              detailHref ? (
                <a class="project-preview-card__title-link" href={detailHref}>
                  {project.name}
                </a>
              ) : (
                <span class="text-primary">{project.name}</span>
              )
            }
          </h2>
          {
            project.external_url && (
              <a
                href={project.external_url}
                target="_blank"
                rel="noopener noreferrer"
                class="project-preview-card__external-btn group-hover:bg-primary"
              >
                <span class="icon-arrow-up-right2 text-primary group-hover:text-secondary transition-all duration-300" />
              </a>
            )
          }
        </div>
        <ul class="project-preview-card__tech-list">
          {
            project.tech_stack.map((tech) => (
              <li
                class={`tech-pill text-xs ${techClassMap[tech] ?? "tech-default"}`}
              >
                {tech}
              </li>
            ))
          }
        </ul>
      </div>
      <p class="project-preview-card__description text-primary">
        {project.description[lang]}
      </p>
    </div>
  </div>
</div>
