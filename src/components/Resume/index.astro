---
import working from "../../assets/memoji_working.webp";
import cv from "../../assets/memoji_cv.webp";
import cv2 from "../../assets/memoji_cv_1.png";
import "./style.css";
---

<section class="glass-card text-primary flex flex-col group h-[318px] md:h-full resume items-center justify-start p-6 rounded-xl relative col-span-1">
  <h2 class="text-4xl font-black">CV / Resume</h2>
  <img src={working.src} alt="Working" class="w-56 h-56 absolute bottom-0 group-hover:opacity-0 transition-all duration-300" />
  <img src={cv2.src} alt="CV" class="w-56 h-56 absolute bottom-0 opacity-0 group-hover:opacity-100 transition-all duration-300" />
</section>