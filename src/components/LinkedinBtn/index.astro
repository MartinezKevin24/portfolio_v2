---
import "./style.css";
import reaction from "../../assets/icons/linkedin_reaction.svg";
---

<a
  href="https://www.linkedin.com/in/kevinmartinezacevedo"
  target="_blank"
  class="group"
>
  <div
    class="glass-card linkedin-container relative w-full h-full rounded-xl flex items-center justify-center"
  >
    <span class="icon-linkedin2 text-[100px] text-primary"></span>
    <img
      src={reaction.src}
      alt="Reaction"
      class="w-14 h-14 absolute -top-2 -right-2 rotate-12 border-4 border-white rounded-full
      group-hover:scale-110 group-hover:rotate-0 transition-all duration-300"
    />
  </div>
</a>
