---
import "./style.css";
import type { ProjectDetail } from "../../types/projects";
import { projects } from "../../data/projects";
import { useTranslations } from "../../i18n/index";
import type { Lang } from "../../i18n/index";
import Button from "../Button/index.astro";
import RelatedProjectCard from "../RelatedProjectCard/index.astro";

interface Props {
  project: ProjectDetail;
}

const { project } = Astro.props;
const lang = (Astro.currentLocale ?? "es") as Lang;
const t = useTranslations(lang);
const base = lang === "en" ? "/en" : "";
const related = projects.filter((p) => p.slug !== project.slug);
const gallery = project.gallery ?? [];
const heroDesktopImage =
  project.images.find((image) => !image.isMobile) ?? project.images[0];
const heroMobileImage =
  project.images.find((image) => image.isMobile) ?? null;
---


<div aria-hidden="true" class="pointer-events-none select-none">
  <div class="detail-glow detail-glow--1"></div>
  <div class="detail-glow detail-glow--2"></div>
  <div class="detail-glow detail-glow--3"></div>
  <div class="detail-glow detail-glow--4"></div>
</div>

<div class="w-full max-w-[1050px] relative mt-10">
  <div class="space-y-8 relative z-10">

    <!-- Hero -->
    <div class="border-b border-white/10 pb-20">
      <div class="grid grid-cols-1 md:grid-cols-[1fr_240px] gap-12 items-center">

        <!-- Left: content -->
        <div class="space-y-8">
          <div class="flex items-center gap-3 flex-wrap">
            <div class="w-12 h-12 rounded-lg overflow-clip">
              <img src={project.icon} alt={project.name + " icon"} class="w-full h-full object-contain" />
            </div>
            <span
              class={`inline-flex items-center rounded-full px-3 py-1 text-xs font-bold uppercase tracking-widest border ${project.url ? "border-green-400/50 text-green-400" : "border-primary/20 text-primary/40"}`}
            >
              {project.url ? "LIVE" : t("project.status.internal")}
            </span>
            <span class="text-primary/70 text-xs font-semibold uppercase tracking-widest">
              {project.role[lang]}
            </span>
          </div>

          <h1 class="text-6xl md:text-7xl font-black text-primary leading-none tracking-tight">
            {project.name}
          </h1>

          <p class="text-primary/80 text-base leading-relaxed">
            {project.description[lang]}
          </p>

          <div class="space-y-4">
            <p class="text-xs font-bold text-primary uppercase tracking-[0.2em]">
              {t("project.tech")}
            </p>
            <div class="flex flex-wrap gap-2">
              {
                project.tech.map((tag) => (
                  <span class={`tech-pill text-xs ${tag.cssClass}`}>
                    {tag.name}
                  </span>
                ))
              }
            </div>
          </div>

          {
            project.url && (
              <div class="max-w-[150px]">
                <Button href={project.url} target="_blank" rel="noopener noreferrer">
                  {t("project.visit")}
                </Button>
              </div>
            )
          }
        </div>

        <!-- Right: preview image -->
        {
          project.images.length > 0 && (
            <div class="rounded-xl shadow-2xl shadow-black/50 overflow-clip h-fit w-fit">
              <div class="relative md:h-[476px] h-full w-full flex items-start overflow-y-auto justify-center">
                {
                  heroMobileImage && (
                    <img
                      src={heroMobileImage.src}
                      alt={heroMobileImage.alt}
                      class="md:block hidden"
                    />
                  )
                }
                <img
                  src={heroDesktopImage.src}
                  alt={heroDesktopImage.alt}
                  class="bg-amber-100 w-full h-full object-contain block md:hidden"
                />
              </div>
            </div>
          )
        }
      </div>
    </div>

    <!-- Highlights grid -->
    <div class="space-y-10 border-b border-white/10 pb-20">
      <h2 class="text-4xl md:text-5xl font-black text-primary">
        {t("project.highlights.title")}
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {
          project.highlights[lang].map((item, i) => (
            <div class="highlight-card border border-white/10 rounded-xl p-5 flex flex-col gap-3">
              <span class="text-3xl font-black text-green-400/40 leading-none">
                {String(i + 1).padStart(2, "0")}
              </span>
              <div class="space-y-1.5">
                <h3 class="font-bold text-primary leading-snug">
                  {item.title}
                </h3>
                <p class="text-primary/70 text-sm leading-relaxed">
                  {item.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Screenshots gallery -->
    {
      gallery.length > 0 && (
        <div data-gallery-section>
          <div class="gallery-sticky-wrap" data-gallery-sticky>
            <div class="gallery-track" data-gallery-track>
              {project.galleryText && (
                <div class="gallery-text-panel">
                  <p class="gallery-text-label">{t("project.images")}</p>
                  <p class="gallery-text-body">{project.galleryText[lang]}</p>
                </div>
              )}
              {gallery.map((img) => (
                <figure
                  class="gallery-slide border border-white/10 gallery-slide-desktop"
                >
                  <div class="gallery-slide-media">
                    <img
                      src={img.src}
                      alt={img.alt}
                      loading="lazy"
                      class="gallery-slide-img"
                    />
                  </div>
                  {
                    img.caption?.[lang] && (
                      <figcaption class="gallery-slide-caption">
                        {img.caption[lang]}
                      </figcaption>
                    )
                  }
                </figure>
              ))}
            </div>
          </div>
        </div>
      )
    }

    <!-- Related projects -->
    <div class="space-y-8 border-t border-white/10 pt-16 relative z-10">
      <p class="font-bold text-primary/50 text-base uppercase tracking-[0.2em]">
        {t("project.related")}
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {
          related.map((relatedProject) => (
            <RelatedProjectCard
              href={`${base}/projects/${relatedProject.slug}`}
              name={relatedProject.name}
              icon={relatedProject.icon}
              role={relatedProject.role[lang]}
              description={relatedProject.description[lang]}
              readMoreLabel={t("project.readMore")}
            />
          ))
        }
      </div>
    </div>

  </div>
</div>

<script is:inline>
  (function () {
    var section = document.querySelector("[data-gallery-section]");
    var sticky = section && section.querySelector("[data-gallery-sticky]");
    var track = section && section.querySelector("[data-gallery-track]");
    if (!section || !sticky || !track) return;

    var maxX = 0;
    var slides = [];

    function isMobile() {
      return window.innerWidth <= 768;
    }

    function setup() {
      var vw = window.innerWidth;
      slides = Array.from(track.querySelectorAll(".gallery-slide"));

      if (isMobile()) {
        section.style.height = "";
        track.style.transform = "none";
        maxX = 0;
        return;
      }

      var lastSlide = track.lastElementChild;
      if (lastSlide) {
        var pr = Math.max(0, Math.floor((vw - lastSlide.offsetWidth) / 2));
        track.style.paddingRight = pr + "px";
      }

      maxX = Math.max(0, track.scrollWidth - vw);
      var stickyHeight = sticky.offsetHeight;
      var endBuffer = Math.max(120, vw * 0.18);
      section.style.height = maxX + stickyHeight + endBuffer + "px";
    }

    function updateBlur(translateX) {
      var vw = window.innerWidth;
      slides.forEach(function (slide) {
        var slideLeft = slide.offsetLeft + translateX;
        var slideWidth = slide.offsetWidth;
        var visibleLeft = Math.max(slideLeft, 0);
        var visibleRight = Math.min(slideLeft + slideWidth, vw);
        var visible = Math.max(0, visibleRight - visibleLeft);
        var ratio = visible / slideWidth;

        if (ratio >= 0.6) {
          slide.style.filter = "blur(0px)";
          slide.style.opacity = "1";
        } else {
          var t = ratio / 0.6;
          slide.style.filter = "blur(" + (14 * (1 - t)).toFixed(1) + "px)";
          slide.style.opacity = (0.25 + 0.75 * t).toFixed(2);
        }
      });
    }

    function onScroll() {
      if (isMobile()) return;
      var translateX = 0;
      if (maxX) {
        var top = section.getBoundingClientRect().top;
        var p = Math.min(1, Math.max(0, -top / maxX));
        translateX = -maxX * p;
      }
      track.style.transform = "translate3d(" + translateX + "px,0,0)";
      updateBlur(translateX);
    }

    setup();
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", function () { setup(); onScroll(); });

    track.querySelectorAll("img").forEach(function (img) {
      img.addEventListener("error", function () {
        var slide = img.closest(".gallery-slide");
        if (slide) slide.style.display = "none";
        setup();
        onScroll();
      });
    });
  })();
</script>
