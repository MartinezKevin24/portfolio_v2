---
import { useTranslations } from "../../i18n/index";
import type { Lang } from "../../i18n/index";

const lang = (Astro.currentLocale ?? "es") as Lang;
const t = useTranslations(lang);
---

<nav class="glass-card rounded-full px-4 py-1.5 inline-flex items-center gap-1 text-sm font-bold text-primary">
  <a href={lang === "es" ? "/" : "/en"} class="px-3 py-1 rounded-full transition-all duration-300 text-primary/70  hover:text-primary">{t("nav.home")}</a>
  <span class="text-primary/25 font-light">|</span>
  <a href="/projects" class="px-3 py-1 rounded-full transition-all duration-300 text-primary/70  hover:text-primary">{t("nav.projects")}</a>
  <span class="text-primary/25 font-light">|</span>
  <a href="/curriculum" class="px-3 py-1 rounded-full transition-all duration-300 text-primary/70  hover:text-primary">{t("nav.resume")}</a>
</nav>
